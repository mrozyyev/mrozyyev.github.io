---
import experiences from "../collections/experiences.json";
import settings from "../collections/site-settings.json";
import AboutExperience from "../components/about-experience.astro";
import PageHeading from "../components/page-heading.astro";
import Layout from "../layouts/main.astro";
---

<Layout title={`${settings.siteName} | ${settings.aboutTitle}`}>
  <section class="relative z-20 max-w-2xl mx-auto my-12 px-7 lg:px-0">
    <PageHeading
      title={settings.aboutTitle}
      description={settings.aboutDescription}
    />

    <img
      src="/assets/images/about.webp"
      class="relative z-30 w-full my-10 rounded-xl"
      alt="Illustration of the Web developer"
    />

    <h2 class="mb-2 text-2xl font-bold dark:text-neutral-200">Short Bio</h2>
    <div
      class="text-sm leading-6 text-gray-600 dark:text-neutral-400 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg"
    >
      {settings.aboutBio.split('\n\n').map((paragraph) => (
        <p class="mb-4">{paragraph}</p>
      ))}
    </div>

    <h2
      class="mt-5 mb-2 text-2xl font-bold lg:mt-10 sm:mt-6 dark:text-neutral-200"
    >
      Experience
    </h2>
    <div class="px-5 py-10">
      {
        experiences.map((experience, loop) => {
          return (
            <>
              {loop == 0 || loop == 1 ? (
                <div class="pb-10 border-l border-gray-200 dark:border-neutral-700">
                  <AboutExperience
                    dates={experience.dates}
                    role={experience.role}
                    company={experience.company}
                    description={experience.description}
                    logo={experience.logo}
                  />
                </div>
              ) : (
                <AboutExperience
                  dates={experience.dates}
                  role={experience.role}
                  company={experience.company}
                  description={experience.description}
                  logo={experience.logo}
                />
              )}
            </>
          );
        })
      }
    </div>

    <h2
      class="mt-5 mb-2 text-2xl font-bold lg:mt-10 sm:mt-6 dark:text-neutral-200"
    >
      Let's Connect
    </h2>
    <p
      class="text-sm leading-6 text-gray-600 dark:text-neutral-400 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg"
    >
      {settings.connectText} <a
        href={settings.social.linkedin}
        target="_blank"
        class="text-indigo-600 underline dark:text-indigo-500">LinkedIn</a
      > | <a
        href={`mailto:${settings.email}`}
        class="text-indigo-600 underline dark:text-indigo-500">Email</a
      >
    </p>
  </section>
</Layout>
